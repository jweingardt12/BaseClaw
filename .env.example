# Yahoo API Credentials (from developer.yahoo.com/apps)
YAHOO_CONSUMER_KEY=your_consumer_key_here
YAHOO_CONSUMER_SECRET=your_consumer_secret_here

# Yahoo Fantasy League Config
LEAGUE_ID=your_league_id_here       # e.g., 469.l.16960
TEAM_ID=your_team_id_here           # e.g., 469.l.16960.t.12

# MCP Server Config (for remote access via Claude.ai)
MCP_SERVER_URL=https://your-domain.com
MCP_AUTH_PASSWORD=your_password_here

# Write Operations (add, drop, trade, lineup changes)
# Set to true to enable write operation MCP tools
ENABLE_WRITE_OPS=false

# Agent Autonomy (for OpenClaw / agent orchestrators)
# full-auto: execute all recommended actions, report after
# semi-auto: execute safe actions (lineups, IL), recommend others for approval
# manual: never execute writes, report recommendations only
AGENT_AUTONOMY=semi-auto

# Tool profile: default, full, draft-day, analysis, automation, all
# Or comma-separated toolset names: core,lineup,waivers,trades,intel
# Default loads ~26 tools (core + lineup + waivers + trades)
MCP_TOOLSET=default

# Preview App (browse all UI views at /preview)
# Set to true to serve the preview dashboard alongside the MCP server
ENABLE_PREVIEW=false
